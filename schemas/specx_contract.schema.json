{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecX Execution Contract",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "objective",
    "domain",
    "task_type",
    "required_agents",
    "required_tools",
    "required_evidence",
    "gates",
    "expected_artifacts",
    "failure_semantics",
    "execution_constraints"
  ],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "required_agents": { "type": "array", "minItems": 1 },
    "required_tools": { "type": "array" },
    "required_evidence": { "type": "array", "minItems": 1 },
    "gates": { "type": "array", "minItems": 1 },
    "expected_artifacts": { "type": "array", "minItems": 1 },
    "failure_semantics": { "type": "object" },
    "execution_constraints": { "type": "object" },
    "human_approval": { "type": "object" },
    "unsupported_features": { "type": "array" }
  },
  "additionalProperties": true
}
